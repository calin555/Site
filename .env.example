# ─── App ───────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://incarcareauto.ro

# ─── SEO (Google Search Console) ───────────────────────────────────────────
# Search Console → Settings → Ownership verification → HTML tag → copy content value
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ─── Google Analytics ────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXNZ2Y8W5W

NEXT_PUBLIC_APP_NAME="ChargePro"

# ─── Supabase ────────────────────────────────────────────────────────────────
# 1. Creează proiect pe https://supabase.com
# 2. Settings → API → Project URL și keys
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Session (customer auth) ───────────────────────────────────────────────
SESSION_SECRET=schimba-cu-un-string-lung-aleatoriu-minim-32-caractere

# ─── Google OAuth (checkout / login) ───────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Stripe (opțional — checkout) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Refund API (Bearer token for POST /api/orders/{orderNumber}/refund)
REFUND_API_SECRET=

# ─── Email Zoho (formular contact) ─────────────────────────────────────────
# Zoho Mail → Settings → Mail Accounts → SMTP
# România/EU: smtp.zoho.eu | Global: smtp.zoho.com
# Folosește parolă de aplicație dacă ai 2FA activat
# Mesajele de pe /contact ajung la emailul din Admin → Setări contact
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_USER=contact@incarcareauto.ro
SMTP_PASSWORD=
EMAIL_FROM=contact@incarcareauto.ro
